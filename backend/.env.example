# AWS Configuration
AWS_REGION=us-east-1

# Amazon Cognito
COGNITO_USER_POOL_ID=<your-cognito-user-pool-id>
COGNITO_CLIENT_ID=<your-cognito-app-client-id>

# Amazon HealthLake
HEALTHLAKE_ENDPOINT=<your-healthlake-endpoint>

# Amazon Transcribe
TRANSCRIBE_BUCKET=medimind-audio-<your-aws-account-id>

# Amazon SNS
SNS_ALERT_TOPIC_ARN=<your-sns-topic-arn>

# Stripe (Billing)
STRIPE_SECRET_KEY=<your-stripe-secret-key>
STRIPE_WEBHOOK_SECRET=<your-stripe-webhook-secret>
STRIPE_PRICE_STARTER=<your-starter-price-id>
STRIPE_PRICE_GROWTH=<your-growth-price-id>
STRIPE_PRICE_ENTERPRISE=<your-enterprise-price-id>

# Amazon SES
SES_FROM_EMAIL=noreply@medimind.ai
